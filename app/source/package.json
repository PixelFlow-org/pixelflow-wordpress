{
  "name": "wordpress",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-dev": "vite build --mode development",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "yalc:link:all": "yalc add @pixelflow-org/plugin-core @pixelflow-org/plugin-ui @pixelflow-org/plugin-features",
    "yalc:link:core": "yalc add @pixelflow-org/plugin-core",
    "yalc:link:ui": "yalc add @pixelflow-org/plugin-ui",
    "yalc:link:features": "yalc add @pixelflow-org/plugin-features",
    "yalc:unlink:all": "yalc remove @pixelflow-org/plugin-core @pixelflow-org/plugin-ui @pixelflow-org/plugin-features && pnpm install"
  },
  "dependencies": {
    "@pixelflow-org/plugin-core": "^2.1.2",
    "@pixelflow-org/plugin-features": "^1.2.7",
    "@pixelflow-org/plugin-ui": "^1.2.3",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-toastify": "^11.0.5",
    "redux-persist": "^6.0.0",
    "reselect": "^5.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  },
  "packageManager": "pnpm@10.33.0"
}
